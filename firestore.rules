rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin check function
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Products collection security
    match /products/{product} {
      // Anyone can see approved products and ads
      allow read: if resource.data.status == 'approved' || resource.data.isAd == true;
      
      // Only the seller or an admin can read unapproved products
      allow read: if request.auth != null && 
                  (request.auth.uid == resource.data.sellerId || isAdmin());

      // Only authenticated users can create products
      allow create: if request.auth != null;

      // Only the owner or an admin can update
      allow update: if request.auth != null && 
                    (request.auth.uid == resource.data.sellerId || isAdmin());

      // Only admins can delete products (for safety)
      allow delete: if isAdmin();
    }

    // Users collection security
    match /users/{userId} {
      allow read: if request.auth != null && 
                  (request.auth.uid == userId || isAdmin());
      
      // Only the authenticated user can create/update their profile
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /userProfiles/{userId} {
      allow read: if request.auth != null &&
                  (request.auth.uid == userId || isAdmin());

      allow create, update: if request.auth != null && request.auth.uid == userId;
    }
  }
}
